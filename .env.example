# Copy this file to .env if you need to override anything.
# The web app does NOT send PDFs to any cloud — extraction is local only (pdfplumber).
# No API keys are required for normal use.

# Web UI (Flask): default port is 8003 via .flaskenv. Override here or with flask --port N.
# FLASK_RUN_PORT=8003
# FLASK_RUN_HOST=127.0.0.1
# FLASK_SECRET_KEY=change-me-in-production

# Optional: default output directory when -o is not set (e.g. output/, exports/)
# OUTPUT_DIR=output

# Optional: web app max upload size in MB (default 40)
# MAX_UPLOAD_MB=40

# Optional: for running extract.py / run.py ask (Anthropic):
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: extraction behaviour (or edit config/extract.json):
# EXTRACT_CONFIG_PATH=config/extract.json
# EXTRACTION_MODE=single
# QUERY_MAX_LENGTH=8000
# USE_STRUCTURED_OUTPUT=false
# LONG_PDF_ENABLED=false
# SYSTEM_PROMPT_PATH=
# PROMPTS_DIR=prompts

# Optional: for extract_gemini.py / extract_openai.py:
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# Optional: for VL extraction (extract_vl.py, Qwen2.5-VL). Run scripts/download_qwen2vl.py first.
# QWEN2VL_MODEL_DIR=models/qwen2.5-vl-7b
# Or set both explicitly:
# QWEN2VL_MODEL_PATH=models/qwen2.5-vl-7b/Qwen2.5-VL-7B-Instruct-Q4_K_M.gguf
# QWEN2VL_MMPROJ_PATH=models/qwen2.5-vl-7b/mmproj-Qwen2.5-VL-7B-Instruct-f16.gguf
