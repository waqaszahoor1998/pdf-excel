# Copy this file to .env if you need to override anything.
# The web app does NOT send PDFs to any cloud — extraction is local only (pdfplumber).
# No API keys are required for normal use.

# Optional: default output directory when -o is not set (e.g. output/, exports/)
# OUTPUT_DIR=output

# Optional: web app max upload size in MB (default 40)
# MAX_UPLOAD_MB=40

# Optional: for running extract.py / run.py ask (Anthropic):
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: extraction behaviour (or edit config/extract.json):
# EXTRACT_CONFIG_PATH=config/extract.json
# EXTRACTION_MODE=single
# QUERY_MAX_LENGTH=8000
# USE_STRUCTURED_OUTPUT=false
# LONG_PDF_ENABLED=false
# SYSTEM_PROMPT_PATH=
# PROMPTS_DIR=prompts

# Optional: for extract_gemini.py / extract_openai.py:
# GEMINI_API_KEY=
# OPENAI_API_KEY=
