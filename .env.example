# Copy this file to .env if you need to override anything.
# The web app does NOT send PDFs to any cloud — extraction is local only (pdfplumber).
# No API keys are required for normal use.

# Optional: for running extract.py / extract_gemini.py / extract_openai.py on already-anonymized data:
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
